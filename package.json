{
  "name": "dnd-soundboard",
  "version": "0.1.0",
  "description": "Local-first soundboard for tabletop RPG sessions",
  "author": "Michele Pasetto <michipase@gmail.com>",
  "homepage": "https://github.com/mp97dev/dnd-soundboard",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "fetch:ytdlp": "bash scripts/fetch-ytdlp.sh",
    "fetch:ytdlp:win": "bash scripts/fetch-ytdlp.sh --win",
    "fetch:ffmpeg": "bash scripts/fetch-ffmpeg.sh",
    "fetch:ffmpeg:win": "bash scripts/fetch-ffmpeg.sh --win",
    "build": "npm run fetch:ytdlp:win && npm run fetch:ffmpeg:win && vite build && electron-builder --win",
    "build:win:zip": "npm run fetch:ytdlp:win && npm run fetch:ffmpeg:win && vite build && electron-builder --win zip",
    "build:linux": "npm run fetch:ytdlp && npm run fetch:ffmpeg && vite build && electron-builder --linux",
    "build:mac": "npm run fetch:ytdlp && vite build && electron-builder --mac",
    "build:renderer": "vite build",
    "test:e2e": "vite build && npx playwright test",
    "server": "node server/index.js",
    "start": "node server/index.js"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@vitejs/plugin-vue": "^6.0.0",
    "concurrently": "^10.0.0",
    "cross-env": "^7.0.3",
    "electron": "^42.0.0",
    "electron-builder": "^26.6.0",
    "vite": "^7.0.0",
    "wait-on": "^8.0.0"
  },
  "dependencies": {
    "bonjour-service": "^1.4.2",
    "castv2-client": "^1.2.0",
    "express": "^4.21.0",
    "pinia": "^2.2.0",
    "vue": "^3.4.0",
    "ws": "^8.18.0"
  },
  "build": {
    "appId": "com.dnd.soundboard",
    "files": [
      "dist/renderer/**",
      "electron/**",
      "server/lib/**"
    ],
    "directories": {
      "output": "dist/out"
    },
    "win": {
      "target": [
        {
          "target": "nsis"
        },
        {
          "target": "zip"
        }
      ],
      "extraResources": [
        {
          "from": "bin",
          "to": "bin",
          "filter": [
            "yt-dlp.exe",
            "ffmpeg.exe",
            "ffprobe.exe"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "${name}-Setup-${version}.${ext}"
    },
    "linux": {
      "target": [
        {
          "target": "deb"
        },
        {
          "target": "AppImage"
        }
      ],
      "category": "AudioVideo",
      "synopsis": "Soundboard for tabletop RPG sessions",
      "extraResources": [
        {
          "from": "bin",
          "to": "bin",
          "filter": [
            "yt-dlp",
            "ffmpeg",
            "ffprobe"
          ]
        }
      ]
    },
    "mac": {
      "extraResources": [
        {
          "from": "bin",
          "to": "bin",
          "filter": [
            "yt-dlp"
          ]
        }
      ]
    }
  }
}
